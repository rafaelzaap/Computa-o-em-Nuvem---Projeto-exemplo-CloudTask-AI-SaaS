# ============================================================================
# CloudTask AI SaaS — variáveis de ambiente (exemplo)
# ----------------------------------------------------------------------------
# Copie este arquivo para `.env` e ajuste os valores conforme a aula em curso.
#   cp .env.example .env
#
# NUNCA versione o arquivo `.env` real (já está no .gitignore).
# Em cada aula, apenas as variáveis correspondentes já fazem efeito.
# ============================================================================

# ----- Geral (aula 4 em diante) ---------------------------------------------
APP_ENV=development            # development | staging | production
APP_NAME=cloudtask-ai-saas
APP_PORT=8000
SECRET_KEY=change-me-please    # gere uma chave aleatória em produção
LOG_LEVEL=INFO
FORCE_HTTPS=false              # true em staging/prod quando houver HTTPS na borda
TRUSTED_HOSTS=localhost,127.0.0.1,0.0.0.0,*
HSTS_MAX_AGE_SECONDS=300

# ----- Banco de dados PostgreSQL (aula 3 em diante) -------------------------
# Local (Docker Compose):
DATABASE_URL=postgresql+psycopg2://cloudtask:cloudtask@db:5432/cloudtask
POSTGRES_USER=cloudtask
POSTGRES_PASSWORD=cloudtask
POSTGRES_DB=cloudtask
# Local (host direto, sem Docker):
# DATABASE_URL=postgresql+psycopg2://cloudtask:cloudtask@localhost:5432/cloudtask
# AWS RDS (exemplo):
# DATABASE_URL=postgresql+psycopg2://USER:PASS@xxxx.rds.amazonaws.com:5432/cloudtask

# ----- Storage / Uploads (aula 5 em diante) ---------------------------------
STORAGE_MODE=local             # local | s3
LOCAL_UPLOADS_DIR=./local_uploads

# Quando STORAGE_MODE=s3:
AWS_REGION=us-east-1
S3_BUCKET_NAME=cloudtask-ai-saas-uploads

# ----- Event store / logs (aula 10 em diante) -------------------------------
EVENT_STORE_MODE=local         # local | dynamodb
LOCAL_EVENTS_FILE=./local_events/events.json

# Quando EVENT_STORE_MODE=dynamodb:
DYNAMODB_TABLE_NAME=cloudtask-events
# DYNAMODB_ENDPOINT_URL=http://localhost:8001   # opcional p/ DynamoDB Local

# ----- Credenciais AWS (NUNCA versionar valores reais) ----------------------
# Em produção use IAM Roles. Localmente prefira `aws configure` (~/.aws/credentials).
# Variáveis abaixo só são necessárias se você optar por injeção via .env:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
