// =============================================================================
// devcontainer.json — CloudTask AI SaaS (Aula 2)
// -----------------------------------------------------------------------------
// MUDANÇA em relação à Aula 1: migramos de `build` direto no Dockerfile
// para `dockerComposeFile` apontando para `docker-compose.yml`. Isso prepara
// a Aula 3, quando adicionaremos o serviço `db` (PostgreSQL 16 compatível
// com Amazon RDS for PostgreSQL) ao mesmo compose — sem nenhuma mudança
// aqui no devcontainer.
//
// Como usar:
//   1. Instalar extensão "Dev Containers" (ms-vscode-remote.remote-containers)
//   2. Abrir esta pasta no VS Code
//   3. F1 → "Dev Containers: Reopen in Container"
//
// Subir tudo sem VS Code:
//   docker compose up --build
//
// Simular produção:
//   docker compose -f docker-compose.yml -f docker-compose.prod.yml up --build
// =============================================================================
{
  "name": "CloudTask AI SaaS — dev (semana 1, via compose)",

  // Aula 2: o compose é a fonte da verdade para o ambiente.
  "dockerComposeFile": ["../docker-compose.yml"],

  // Serviço ao qual o VS Code se conecta. Em aulas futuras outros serviços
  // (db, etc.) sobem juntos automaticamente.
  "service": "api",

  // Pasta aberta dentro do container. Bate com o `volumes: .:/app` do compose.
  "workspaceFolder": "/app",

  // Quando o VS Code fechar, para os containers do compose (libera memória).
  "shutdownAction": "stopCompose",

  // Usuário não-root criado no Dockerfile.
  "remoteUser": "appuser",

  // Mantém o container vivo enquanto o VS Code estiver conectado.
  // O uvicorn é iniciado manualmente pelo aluno (terminal ou debugger),
  // o que facilita o ensino e o debug interativo.
  "overrideCommand": true,

  // Features = "add-ons" oficiais instalados dentro do container.
  "features": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },

  // Extensões e configurações do VS Code aplicadas automaticamente.
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.debugpy",
        "charliermarsh.ruff",
        "tamasfe.even-better-toml",
        "redhat.vscode-yaml",
        "ms-azuretools.vscode-docker"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/home/appuser/.local/bin/python",
        "python.terminal.activateEnvironment": false,
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
          "source.fixAll.ruff": "explicit",
          "source.organizeImports.ruff": "explicit"
        },
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff"
        },
        "files.exclude": {
          "**/__pycache__": true,
          "**/.pytest_cache": true,
          "**/.ruff_cache": true
        }
      }
    }
  },

  // Roda uma vez, logo após o container subir pela primeira vez.
  "postCreateCommand": "python -V && pip list",

  // Portas encaminhadas automaticamente para o host.
  // (As mesmas portas já estão publicadas pelo compose; aqui é só metadata
  // para o painel "Ports" do VS Code mostrar rótulos amigáveis.)
  "forwardPorts": [8000, 5678],
  "portsAttributes": {
    "8000": { "label": "FastAPI",  "onAutoForward": "notify" },
    "5678": { "label": "debugpy",  "onAutoForward": "silent" }
  }
}
